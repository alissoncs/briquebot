{
  "name": "briquebot",
  "private": true,
  "workspaces": ["web", "api"],
  "scripts": {
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run start:dev -w api",
    "build": "npm run build -w web && npm run build -w api",
    "build:web": "npm run build -w web",
    "build:api": "npm run build -w api",
    "start:web": "npm run start -w web",
    "start:api": "npm run start -w api"
  }
}

